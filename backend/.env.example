# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Database Configuration
# Option 1: Avian Database (Primary)
AVIAN_CONNECTION_STRING=your-avian-connection-string

# Option 2: SQLite (Fallback - default)
DATABASE_URL=sqlite:///nexora.db

# Option 3: PostgreSQL (Production)
# DATABASE_URL=postgresql://user:password@localhost:5432/nexora

# CORS Configuration
CORS_ORIGINS=*

# Server Configuration
HOST=0.0.0.0
PORT=5000
